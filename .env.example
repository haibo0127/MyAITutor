# 基础配置
ENV=production
API_HOST=0.0.0.0
API_PORT=8000
SECRET_KEY=your_secure_secret_key_here  # 生成方式: openssl rand -hex 32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=360

# 阿里云/千问配置
DASHSCOPE_API_KEY=your_dashscope_api_key  # 通义千问API Key
#OPENCLAW_API_KEY=your_openclaw_api_key     # OpenClaw API Key

# 数据库路径
DATABASE_URL=sqlite:///./data/db.sqlite
CHROMA_DB_PATH=./data/chroma_db
UPLOAD_DIR=./data/uploads

# 安全配置
ALLOWED_ORIGINS=*